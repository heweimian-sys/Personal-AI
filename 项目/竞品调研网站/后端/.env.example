# ============================================
# 知行·认知加速器 环境变量模板
# 复制此文件为 .env 并填入真实值
# ============================================

# 应用配置
APP_NAME=知行
DEBUG=true

# 数据库（SQLite，无需额外服务）
DATABASE_URL=sqlite+aiosqlite:///./data/zhixin.db

# Firecrawl 搜索服务（自部署，二选一）
# 参考：https://github.com/firecrawl/firecrawl
# 自部署后填入你的 Firecrawl 服务地址和 API Key
FIRECRAWL_API_URL=http://localhost:3002/v1
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# Tavily 搜索服务（免费推荐，二选一）
# 注册：https://tavily.com → 免费 1000 次/月
# 配置后自动优先使用，无需自部署
TAVILY_API_KEY=tvly-your-key

# DeepSeek AI 服务
# 注册地址：https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# CORS（前端地址）
CORS_ORIGINS=http://localhost:3000
